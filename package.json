{
  "name": "4ChanMediaDownloader",
  "version": "1.0.4",
  "repository": "https://github.com/TPoret/4ChanMediaDownloader.git",
  "author": "TPT",
  "license": "MIT",
  "private": false,
  "scripts": {
    "build": "esbuild src/content_script.js --target=firefox57 --bundle --outfile=content.js && esbuild src/background_script.js --target=firefox57 --bundle --outfile=background.js",
    "test:e2e": "yarn build && playwright test --config e2e/playwright.config.js",
    "package": "yarn build && web-ext build",
    "release": "node scripts/release.js"
  },
  "jest": {
    "transform": {
      "\\.[jt]sx?$": "babel-jest"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ]
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@playwright/test": "^1.61.0",
    "babel-jest": "^30.4.1",
    "esbuild": "^0.28.1",
    "geckodriver": "^6.1.0",
    "jest": "^30.4.2",
    "selenium-webdriver": "^4.45.0",
    "web-ext": "^10.4.0"
  },
  "dependencies": {
    "mobx": "^6.9.0"
  }
}
